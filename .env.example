# Copy this file to .env and fill in your values.
# Get these from your Supabase project: Settings → API

# The full URL of your Supabase project (e.g. https://xxxx.supabase.co)
VITE_SUPABASE_URL=https://<YOUR_PROJECT_REF>.supabase.co

# The anon/public key from Settings → API → Project API keys
VITE_SUPABASE_PUBLISHABLE_KEY=<YOUR_SUPABASE_ANON_KEY>

# Your project reference ID (the slug in your Supabase project URL)
VITE_SUPABASE_PROJECT_ID=<YOUR_PROJECT_REF>

# --- Sentry (frontend observability) ---
# Optional. Sentry only initializes in production builds when this DSN is set,
# so leaving it blank disables all error/performance/replay reporting locally.
# Get it from your Sentry project: Settings → Client Keys (DSN).
VITE_SENTRY_DSN=

# Optional. Fraction of transactions sampled for performance tracing (0.0–1.0).
# Defaults to 0.1 when unset. Keep low to stay within the Sentry free tier.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Build-only secrets for source map upload — set these in Vercel, never commit them:
#   SENTRY_AUTH_TOKEN  Auth token used by @sentry/vite-plugin to upload source maps
#   SENTRY_ORG         Sentry organization slug
#   SENTRY_PROJECT     Sentry project slug
# When SENTRY_AUTH_TOKEN is absent the build still succeeds; maps just aren't uploaded.
